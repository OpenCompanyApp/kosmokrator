{
    "name": "kosmokrator/kosmokrator",
    "description": "KosmoKrator — AI coding agent for the terminal",
    "keywords": ["coding-agent", "cli", "ai", "terminal", "tui"],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "OpenCompany"
        }
    ],
    "require": {
        "php": "^8.4",
        "amphp/amp": "^3.1",
        "amphp/http-client": "^5.3",
        "league/commonmark": "^2.9",
        "league/html-to-markdown": "^5.1",
        "opencompany/prism-codex": "dev-main",
        "opencompanyapp/integration-clickup": "@dev",
        "opencompanyapp/integration-coingecko": "@dev",
        "opencompanyapp/integration-core": "@dev",
        "opencompanyapp/integration-instantly": "@dev",
        "opencompanyapp/integration-plane": "@dev",
        "opencompanyapp/integration-plausible": "@dev",
        "opencompanyapp/prism-relay": "dev-main",
        "prism-php/prism": "^0.100",
        "revolt/event-loop": "^1.0",
        "sebastian/diff": "^7.0",
        "symfony/console": "^7.4|^8.0",
        "symfony/event-dispatcher": "^7.4|^8.0",
        "symfony/finder": "^7.4|^8.0",
        "symfony/process": "^7.4|^8.0",
        "symfony/tui": "dev-tui",
        "symfony/yaml": "^7.4|^8.0",
        "tempest/highlight": "^2.16",
        "twig/twig": "^3.0|^4.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25",
        "nunomaduro/collision": "^8.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^12.0"
    },
    "repositories": [
        {
            "name": "integration-core",
            "type": "path",
            "url": "integrations/core",
            "options": {
                "symlink": false
            }
        },
        {
            "name": "integrations-monorepo",
            "type": "path",
            "url": "integrations/packages/*",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "package",
            "package": {
                "name": "symfony/tui",
                "version": "dev-tui",
                "type": "library",
                "description": "Provides a terminal UI framework for building rich, interactive CLI applications in PHP",
                "license": "MIT",
                "source": {
                    "type": "git",
                    "url": "https://github.com/fabpot/symfony.git",
                    "reference": "07fa8230295091e5d1e56883b0d73a0649cb316d"
                },
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/fabpot/symfony/zipball/07fa8230295091e5d1e56883b0d73a0649cb316d",
                    "reference": "07fa8230295091e5d1e56883b0d73a0649cb316d"
                },
                "require": {
                    "php": ">=8.4",
                    "revolt/event-loop": "^1.0",
                    "symfony/event-dispatcher": "^8.0",
                    "symfony/string": "^8.0"
                },
                "autoload": {
                    "psr-4": {
                        "Symfony\\Component\\Tui\\": "src/Symfony/Component/Tui/"
                    },
                    "exclude-from-classmap": [
                        "/Tests/"
                    ]
                },
                "minimum-stability": "dev"
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/OpenCompanyApp/prism-codex.git"
        },
        {
            "type": "vcs",
            "url": "https://github.com/OpenCompanyApp/prism-relay.git"
        }
    ],
    "autoload": {
        "psr-4": {
            "Kosmokrator\\": "src/",
            "Athanor\\": "src/Athanor/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Kosmokrator\\Tests\\": "tests/"
        },
        "files": [
            "stubs/lua-sandbox-polyfill.php"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": ["bin/kosmo", "bin/kosmokrator"]
}
