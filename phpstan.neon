parameters:
    level: 5
    paths:
        - src
    stubFiles:
        - stubs/lua-sandbox.stub.php
    ignoreErrors:
        # Animation frame count guards in UI/Ansi/* — always true/false due to count() ranges
        - '#Comparison operation#'
        # Write-only properties in animation/UI classes
        - '#Property.*never read, only written#'
        # Unused animation character constants
        - '#Constant.*unused#'
        # Nullsafe access that's always non-null on left side of ??
        - '#nullsafe property access.*unnecessary#'
        # Defensive null coalescing on offsets
        - '#Offset.*on left side of \?\? always exists#'
        - '#Offset.*on left side of \?\? does not exist#'
        # Always-true/false strict comparisons in UI code
        - '#Strict comparison.*always evaluate to (true|false)#'
        # Dead code after always-true conditions
        - '#Unreachable statement#'
        # Ternary with always-true condition
        - '#Ternary operator condition is always true#'
        # is_array() on known array types
        - '#Call to function is_array\(\).*always evaluate to true#'
        # Match arm always true/false comparisons
        - '#Match arm comparison.*always (true|false)#'
        # All nullsafe property access usage
        - '#Using nullsafe property access#'
        # Unused methods in TuiModalManager
        - '#Method.*is unused#'
        # API mismatches with vendor code (extra parameters)
        - '#(Static )?[Mm]ethod.*invoked with .* parameters, .* required#'
        # CLI script variables ($argc/$argv)
        - '#Variable \$arg[vc] might not be defined#'
        # Vendor API type mismatches (Container vs Application)
        - '#Parameter.*expects Illuminate\\Contracts\\Foundation\\Application.*Illuminate\\Container\\Container given#'
        # By-ref type widening for subagent batch (mixed from Prism ToolResult)
        - '#Parameter &\$subagentBatch by-ref type#'
        # Offset in isset() always exists
        - '#Offset.*in isset\(\) always exists#'
        # @param references unknown parameter
        - '#PHPDoc tag @param references unknown parameter#'
        # Audio scripts using unknown class LlmClientInterface (standalone CLI scripts)
        - '#unknown class LlmClientInterface#'
        # Audio scripts passing wrong type to constructor
        - '#Parameter \$llm.*expects.*LlmClientInterface.*LlmClientInterface given#'
        # Vendor classes that may not be present in all composer.lock versions
        - '#Call to static method.*on an unknown class OpenCompany#'
        # Variable always null in loop (false positive for SSE stream parsing)
        - '#Variable \$lastFinishReason on left side of \?\? always exists and is always null#'
        # Integration account type widening
        - "#Offset 'accounts'.*does not accept type#"
        - '#Method.*IntegrationManager::getToolCatalog\(\) should return#'
        # Native tool bridge return shape (dynamic tool parameter shapes)
        - '#Method.*NativeToolBridge::listTools\(\) should return#'
        # Lua tool invoker interface variance
        - '#Parameter.*\$invoker.*ExecuteLuaTool constructor#'
        # LlmStreamingEvent PHPDoc type drift
        - '#PHPDoc tag @param for parameter \$finishReason#'
        - '#PHPDoc type for property.*LlmStreamingEvent.*finishReason#'
        - '#Parameter \$finishReason of method.*LlmStreamingEvent.*invalid type#'
        - '#Property.*LlmStreamingEvent.*finishReason.*unknown class#'
        # PrismService toolCall argument type (Prism API returns array, we need string)
        - '#Parameter.*\$arguments of static method.*LlmStreamingEvent::toolCall\(\)#'
        # ExecuteLuaTool empty() on known-defined variable
        - '#Variable \$lines in empty\(\) always exists#'
        # TUI closure type mismatch for queueMessageSilent
        - '#Parameter \$queueMessageSilent.*expects Closure\(string\): void.*Closure\(string\): string#'
    reportUnmatchedIgnoredErrors: false
