const surfaceSnippets = {
  terminal: `kosmo

> fix the failing tests and explain the change

‚óŹ reading failing test output
‚óŹ editing src/Auth/TokenVerifier.php
‚óŹ running vendor/bin/phpunit --filter TokenVerifierTest

Done. 2 files changed, tests passing.`,
  headless: `kosmo -p "review this branch" \\
  --mode plan \\
  --permission-mode guardian \\
  -o stream-json

kosmo integrations:plane list_issues \\
  --account work \\
  --json`,
  sdk: `use Kosmokrator\\Sdk\\AgentBuilder;

$result = AgentBuilder::create()
    ->forProject('/repo')
    ->withMode('edit')
    ->withPermissionMode('guardian')
    ->build()
    ->collect('Implement the missing tests');`,
  acp: `kosmo acp --cwd /repo

// newline-delimited JSON-RPC over stdio
// session/prompt
// session/request_permission
// kosmo/subagents/tree
// kosmo/tool/result`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>KosmoKrator - Terminal AI Coding Agent</title>
    <meta
      name="description"
      content="KosmoKrator is a terminal AI coding agent with headless execution, ACP, PHP SDK, Lua, integrations, MCP, and parallel subagents."
    />
    <meta property="og:title" content="KosmoKrator - Terminal AI Coding Agent" />
    <meta property="og:description" content="A terminal coding agent with matching headless automation surfaces." />
    <meta property="og:image" content="/og-image.svg" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="min-h-screen overflow-x-hidden text-kosmo-text font-sans bg-[radial-gradient(circle_at_8%_10%,rgba(220,20,60,0.18),transparent_28rem),radial-gradient(circle_at_92%_20%,rgba(255,92,117,0.12),transparent_26rem),linear-gradient(180deg,#07070d_0%,#0c0c14_58%,#07070d_100%)]">
    <header class="w-[min(1180px,calc(100vw-2rem))] mx-auto flex items-center justify-between gap-4 py-4 max-[920px]:flex-col max-[920px]:items-start">
      <a class="text-kosmo-text no-underline font-extrabold flex items-center gap-4" href="/" aria-label="KosmoKrator home">
        <img src="/favicon.svg" alt="" width="28" height="28" />
        <span>KosmoKrator</span>
      </a>
      <nav class="flex flex-wrap items-center gap-4 justify-end max-[920px]:justify-start max-[560px]:w-full max-[560px]:gap-2.5" aria-label="Main navigation">
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/docs/getting-started">Docs</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/docs/installation">Install</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/integrations">Integrations</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/docs/headless">Headless</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/docs/acp">ACP</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="/docs/changelog">Changelog</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem] max-[560px]:text-[0.88rem]" href="https://github.com/OpenCompanyApp/kosmokrator">GitHub</a>
      </nav>
    </header>

    <main>
      <section class="grid grid-cols-[minmax(0,1fr)_minmax(360px,520px)] items-center gap-[clamp(2rem,5vw,5rem)] w-[min(1180px,calc(100vw-2rem))] mx-auto pt-16 pb-18 max-[920px]:w-[min(100vw-1.25rem,720px)] max-[920px]:grid-cols-1 max-[920px]:pt-8">
        <div class="min-w-0">
          <pre
            class="overflow-x-auto w-max max-w-full mb-8 p-0 border-0 bg-transparent text-kosmo-crimson font-mono font-bold text-[clamp(0.28rem,0.72vw,0.5rem)] leading-[1.18]"
            aria-label="KosmoKrator ASCII logo"
          >{asciiLogo}</pre>
          <p class="mb-3 text-kosmo-hot text-xs font-extrabold tracking-[0.14em] uppercase">Terminal AI coding agent for real repositories</p>
          <h1 class="max-w-[720px] m-0 leading-none text-[clamp(2.85rem,5.4vw,4.75rem)] tracking-normal">The coding agent you run from the terminal.</h1>
          <p class="max-w-[760px] mt-5 text-kosmo-muted leading-relaxed text-[clamp(1.03rem,1.55vw,1.24rem)] tracking-normal">
            KosmoKrator gives you a shell-first agent with TUI and ANSI renderers, permissions,
            persistent sessions, context management, Lua code mode, integrations, MCP, ACP,
            a PHP SDK, and parallel subagents.
          </p>
          <div class="flex flex-wrap gap-3 mt-8">
            <a class="inline-flex items-center justify-center min-h-[44px] px-4 py-3 border rounded-md text-kosmo-text font-bold no-underline bg-kosmo-crimson border-kosmo-crimson" href="/docs/installation">Install KosmoKrator</a>
            <a class="inline-flex items-center justify-center min-h-[44px] px-4 py-3 border border-kosmo-border rounded-md text-kosmo-text font-bold no-underline bg-white/[0.05]" href="/docs/getting-started">Read the docs</a>
            <span class="self-center inline-flex items-center justify-center min-h-[32px]">
              <a
                class="github-button"
                href="https://github.com/OpenCompanyApp/kosmokrator"
                data-icon="octicon-star"
                data-size="large"
                data-show-count="true"
                aria-label="Star OpenCompanyApp/kosmokrator on GitHub"
              >Star</a>
            </span>
          </div>
        </div>

        <div class="min-w-0 max-w-full overflow-hidden border border-kosmo-border rounded-[10px] bg-kosmo-surface shadow-[0_24px_70px_rgba(0,0,0,0.34)]" aria-label="KosmoKrator runtime examples">
          <div class="grid grid-cols-4 border-b border-white/[0.08] max-[560px]:grid-cols-2" role="tablist" aria-label="Runtime surfaces">
            {Object.keys(surfaceSnippets).map((key, index) => (
              <button
                type="button"
                class:list={[
                  'min-h-[44px] border-0 border-r border-white/[0.08] uppercase cursor-pointer last:border-r-0 font-bold text-xs font-mono',
                  index === 0 ? 'bg-kosmo-crimson/15 text-kosmo-text' : 'bg-white/[0.03] text-kosmo-muted',
                ]}
                data-surface-tab={key}
                role="tab"
                aria-selected={index === 0 ? 'true' : 'false'}
                aria-controls={`surface-${key}`}
                id={`tab-${key}`}
              >
                {key}
              </button>
            ))}
          </div>
          {Object.entries(surfaceSnippets).map(([key, snippet], index) => (
            <pre
              id={`surface-${key}`}
              class:list={[
                index === 0 ? 'block' : 'hidden',
                'min-h-[430px] m-0 p-5 overflow-auto bg-kosmo-code-bg-2 whitespace-pre',
                'text-kosmo-code-text font-mono font-medium text-[0.86rem] leading-[1.75]',
                'max-[560px]:min-h-[330px] max-[560px]:text-[0.78rem] max-[560px]:whitespace-pre-wrap max-[560px]:[overflow-wrap:anywhere]',
              ]}
              data-surface-panel={key}
              role="tabpanel"
              aria-labelledby={`tab-${key}`}
              hidden={index !== 0}
            ><code class="font-[inherit]">{snippet}</code></pre>
          ))}
        </div>
      </section>

      <section class="w-[min(1180px,calc(100vw-2rem))] mx-auto py-18 border-t border-white/[0.08] max-[920px]:w-[min(100vw-1.25rem,720px)]" id="install">
        <div class="grid gap-2 max-w-[760px] mb-5">
          <p class="mb-3 text-kosmo-hot text-xs font-extrabold tracking-[0.14em] uppercase">Install</p>
          <h2 class="m-0 leading-tight text-[clamp(2rem,4vw,3.2rem)] tracking-normal">Choose the runtime package that matches the machine.</h2>
        </div>
        <div class="overflow-hidden border border-white/10 rounded-lg bg-white/[0.04]" aria-label="Install methods">
          <div class="grid grid-cols-4 border-b border-white/10 max-[560px]:grid-cols-2" role="tablist" aria-label="Install methods">
            <button type="button" role="tab" aria-selected="true" aria-controls="install-static" id="install-tab-static" data-install-tab="static" class="min-h-[48px] p-3 border-0 border-r border-white/[0.08] bg-kosmo-crimson/15 text-kosmo-text cursor-pointer last:border-r-0 font-extrabold text-xs font-mono">Static binary</button>
            <button type="button" role="tab" aria-selected="false" aria-controls="install-phar" id="install-tab-phar" data-install-tab="phar" class="min-h-[48px] p-3 border-0 border-r border-white/[0.08] bg-white/[0.03] text-kosmo-muted cursor-pointer last:border-r-0 font-extrabold text-xs font-mono">PHAR</button>
            <button type="button" role="tab" aria-selected="false" aria-controls="install-source" id="install-tab-source" data-install-tab="source" class="min-h-[48px] p-3 border-0 border-r border-white/[0.08] bg-white/[0.03] text-kosmo-muted cursor-pointer last:border-r-0 font-extrabold text-xs font-mono">Source checkout</button>
            <button type="button" role="tab" aria-selected="false" aria-controls="install-termux" id="install-tab-termux" data-install-tab="termux" class="min-h-[48px] p-3 border-0 border-r border-white/[0.08] bg-white/[0.03] text-kosmo-muted cursor-pointer last:border-r-0 font-extrabold text-xs font-mono">Termux</button>
          </div>
          <section id="install-static" class="p-5 block" role="tabpanel" aria-labelledby="install-tab-static" data-install-panel="static">
            <h3 class="m-0 mb-2 text-kosmo-text text-base">Static binary</h3>
            <p class="max-w-[720px] m-0 mb-4 text-kosmo-muted text-[0.94rem] leading-relaxed">No PHP dependency. Recommended for normal terminal use on macOS and Linux.</p>
            <pre class="overflow-x-auto m-0 p-4 rounded-md bg-kosmo-code-bg-2 text-kosmo-code-text font-mono font-medium text-[0.86rem] leading-[1.65]"><code>curl -fsSL https://raw.githubusercontent.com/OpenCompanyApp/kosmokrator/main/install.sh | bash</code></pre>
          </section>
          <section id="install-phar" class="p-5 hidden" role="tabpanel" aria-labelledby="install-tab-phar" data-install-panel="phar" hidden>
            <h3 class="m-0 mb-2 text-kosmo-text text-base">PHAR</h3>
            <p class="max-w-[720px] m-0 mb-4 text-kosmo-muted text-[0.94rem] leading-relaxed">Single PHP archive for systems with PHP 8.4 and the required extensions.</p>
            <pre class="overflow-x-auto m-0 p-4 rounded-md bg-kosmo-code-bg-2 text-kosmo-code-text font-mono font-medium text-[0.86rem] leading-[1.65]"><code>php kosmokrator.phar</code></pre>
          </section>
          <section id="install-source" class="p-5 hidden" role="tabpanel" aria-labelledby="install-tab-source" data-install-panel="source" hidden>
            <h3 class="m-0 mb-2 text-kosmo-text text-base">Source checkout</h3>
            <p class="max-w-[720px] m-0 mb-4 text-kosmo-muted text-[0.94rem] leading-relaxed">Best for contributors and local development.</p>
            <pre class="overflow-x-auto m-0 p-4 rounded-md bg-kosmo-code-bg-2 text-kosmo-code-text font-mono font-medium text-[0.86rem] leading-[1.65] max-[560px]:whitespace-pre-wrap max-[560px]:[overflow-wrap:anywhere]"><code>git clone https://github.com/OpenCompanyApp/kosmokrator.git
cd kosmokrator
composer install
bin/kosmo</code></pre>
          </section>
          <section id="install-termux" class="p-5 hidden" role="tabpanel" aria-labelledby="install-tab-termux" data-install-panel="termux" hidden>
            <h3 class="m-0 mb-2 text-kosmo-text text-base">Termux</h3>
            <p class="max-w-[720px] m-0 mb-4 text-kosmo-muted text-[0.94rem] leading-relaxed">Run the ANSI renderer on Android with PHP, Composer, and local storage access.</p>
            <pre class="overflow-x-auto m-0 p-4 rounded-md bg-kosmo-code-bg-2 text-kosmo-code-text font-mono font-medium text-[0.86rem] leading-[1.65] max-[560px]:whitespace-pre-wrap max-[560px]:[overflow-wrap:anywhere]"><code>pkg install php composer git
bin/kosmo --renderer=ansi</code></pre>
          </section>
        </div>
      </section>

      <section class="w-[min(1180px,calc(100vw-2rem))] mx-auto py-18 border-t border-white/[0.08] max-[920px]:w-[min(100vw-1.25rem,720px)]">
        <div class="grid gap-2 max-w-[760px] mb-5">
          <p class="mb-3 text-kosmo-hot text-xs font-extrabold tracking-[0.14em] uppercase">Runtime surfaces</p>
          <h2 class="m-0 leading-tight text-[clamp(2rem,4vw,3.2rem)] tracking-normal">One agent core, several ways to operate it.</h2>
        </div>
        <div class="grid grid-cols-4 gap-3.5 max-[920px]:grid-cols-2 max-[560px]:grid-cols-1">
          <a class="min-w-0 p-4 border border-white/10 rounded-lg bg-white/[0.04] text-inherit no-underline hover:border-kosmo-crimson" href="/docs/headless">
            <strong class="block mb-2 text-kosmo-text text-base">Headless CLI</strong>
            <span class="block m-0 text-kosmo-muted text-[0.93rem] leading-relaxed">Use `kosmo -p`, JSON output, stream-json, and direct integrations/MCP commands from automation.</span>
          </a>
          <a class="min-w-0 p-4 border border-white/10 rounded-lg bg-white/[0.04] text-inherit no-underline hover:border-kosmo-crimson" href="/docs/acp">
            <strong class="block mb-2 text-kosmo-text text-base">ACP server</strong>
            <span class="block m-0 text-kosmo-muted text-[0.93rem] leading-relaxed">Expose terminal-equivalent sessions, permissions, tools, subagents, integrations, MCP, and Lua over stdio.</span>
          </a>
          <a class="min-w-0 p-4 border border-white/10 rounded-lg bg-white/[0.04] text-inherit no-underline hover:border-kosmo-crimson" href="/docs/sdk">
            <strong class="block mb-2 text-kosmo-text text-base">PHP SDK</strong>
            <span class="block m-0 text-kosmo-muted text-[0.93rem] leading-relaxed">Embed headless runs and direct runtime helpers in PHP applications without creating another engine.</span>
          </a>
          <a class="min-w-0 p-4 border border-white/10 rounded-lg bg-white/[0.04] text-inherit no-underline hover:border-kosmo-crimson" href="/docs/lua">
            <strong class="block mb-2 text-kosmo-text text-base">Lua code mode</strong>
            <span class="block m-0 text-kosmo-muted text-[0.93rem] leading-relaxed">Compose file tools, integrations, MCP calls, and helper functions in discoverable scripts.</span>
          </a>
          <a class="min-w-0 p-4 border border-white/10 rounded-lg bg-white/[0.04] text-inherit no-underline hover:border-kosmo-crimson" href="/integrations">
            <strong class="block mb-2 text-kosmo-text text-base">Integration catalog</strong>
            <span class="block m-0 text-kosmo-muted text-[0.93rem] leading-relaxed">Browse generated CLI, Lua, and MCP gateway docs for every OpenCompany integration.</span>
          </a>
        </div>
      </section>
    </main>

    <footer class="flex items-center gap-4 justify-start py-8 pb-12 text-kosmo-muted border-t border-white/[0.08] w-[min(1180px,calc(100vw-2rem))] mx-auto max-[920px]:w-[min(100vw-1.25rem,720px)]">
      <span class="text-kosmo-text font-extrabold">KosmoKrator</span>
      <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/docs">Documentation</a>
      <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/integrations">Integrations</a>
      <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/docs/changelog">Changelog</a>
      <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/docs/architecture">Architecture</a>
      <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="https://github.com/OpenCompanyApp/kosmokrator">GitHub</a>
    </footer>

    <script>
      const tabs = Array.from(document.querySelectorAll('[data-surface-tab]'));
      const panels = Array.from(document.querySelectorAll('[data-surface-panel]'));

      function selectSurface(key) {
        tabs.forEach((tab) => {
          const selected = tab.dataset.surfaceTab === key;
          tab.setAttribute('aria-selected', selected ? 'true' : 'false');
          tab.classList.toggle('bg-kosmo-crimson/15', selected);
          tab.classList.toggle('text-kosmo-text', selected);
          tab.classList.toggle('bg-white/[0.03]', !selected);
          tab.classList.toggle('text-kosmo-muted', !selected);
        });

        panels.forEach((panel) => {
          const selected = panel.dataset.surfacePanel === key;
          panel.hidden = !selected;
        });
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => selectSurface(tab.dataset.surfaceTab));
        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight'].includes(event.key)) return;
          event.preventDefault();
          const direction = event.key === 'ArrowRight' ? 1 : -1;
          const next = tabs[(index + direction + tabs.length) % tabs.length];
          next.focus();
          selectSurface(next.dataset.surfaceTab);
        });
      });

      const installTabs = Array.from(document.querySelectorAll('[data-install-tab]'));
      const installPanels = Array.from(document.querySelectorAll('[data-install-panel]'));

      function selectInstall(key) {
        installTabs.forEach((tab) => {
          const selected = tab.dataset.installTab === key;
          tab.setAttribute('aria-selected', selected ? 'true' : 'false');
          tab.classList.toggle('bg-kosmo-crimson/15', selected);
          tab.classList.toggle('text-kosmo-text', selected);
          tab.classList.toggle('bg-white/[0.03]', !selected);
          tab.classList.toggle('text-kosmo-muted', !selected);
        });

        installPanels.forEach((panel) => {
          const selected = panel.dataset.installPanel === key;
          panel.hidden = !selected;
        });
      }

      installTabs.forEach((tab, index) => {
        tab.addEventListener('click', () => selectInstall(tab.dataset.installTab));
        tab.addEventListener('keydown', (event) => {
          if (!['ArrowLeft', 'ArrowRight'].includes(event.key)) return;
          event.preventDefault();
          const direction = event.key === 'ArrowRight' ? 1 : -1;
          const next = installTabs[(index + direction + installTabs.length) % installTabs.length];
          next.focus();
          selectInstall(next.dataset.installTab);
        });
      });

    </script>
    <script async defer src="https://buttons.github.io/buttons.js"></script>
  </body>
</html>
