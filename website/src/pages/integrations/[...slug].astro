          <h2>Related {integration.name} CLI Pages</h2>
          <div class="grid grid-cols-[repeat(auto-fit,minmax(230px,1fr))] gap-3">
            {cliEnvironments.filter((item) => item.slug !== environment.slug).map((item) => (
              <a class="grid gap-1.5 p-4 border border-kosmo-white-border-strong rounded-lg bg-white/[0.04] text-kosmo-text no-underline" href={`${integrationUrl(integration, 'cli')}/${item.slug}`}>
                <strong>{item.titleSuffix}</strong>
                <span>{integration.name} CLI for {item.label}.</span>
              </a>
            ))}
          </div>
        </section>
      )}
    </main>

    <script>
      // Function card toggle
      document.querySelectorAll('.function-card-header').forEach(header => {
        header.addEventListener('click', () => {
          header.parentElement.classList.toggle('expanded');
        });
      });

      // Copy buttons
      document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          const wrapper = (btn as HTMLElement).closest('.command-cell-wrapper');
          if (!wrapper) return;
          const code = wrapper.querySelector('code');
          if (!code) return;
          navigator.clipboard.writeText(code.textContent || '').then(() => {
            btn.textContent = 'copied';
            setTimeout(() => { btn.textContent = 'copy'; }, 1500);
          }).catch(() => {});
        });
      });
    </script>
  </body>
</html>
