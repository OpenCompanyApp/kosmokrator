---
import '../../styles/tailwind.css';
import { createMarkdownProcessor } from '@astrojs/markdown-remark';
import AnalyticsContext from '../../components/AnalyticsContext.astro';
import AnalyticsScripts from '../../components/AnalyticsScripts.astro';
import CommandBlock from '../../components/CommandBlock.astro';
import IntegrationSideRail from '../../components/IntegrationSideRail.astro';
import IntegrationToc from '../../components/IntegrationToc.astro';
import MegaFooter from '../../components/MegaFooter.astro';
import {
  credentialTypeLabel,
  getIntegrations,
  integrationUrl,
  jsonExampleForTool,
  operationLabel,
  toolFullName,
  toolMcpName,
  type Integration,
  type IntegrationTool,
} from '../../lib/integrations-catalog';
import {
  SITE_URL,
  articleJsonLd,
  breadcrumbJsonLd,
  cliEnvironments,
  faqJsonLd,
  integrationCliTitle,
  integrationKeywords,
  integrationMcpTitle,
  integrationOverviewTitle,
  jsonLd,
  matrixClients,
  ogImageUrl,
  shouldIndexIntegration,
  siteUrl,
} from '../../lib/seo';

type PageType = 'overview' | 'lua' | 'cli' | 'mcp';
type TocItem = { id: string; label: string; depth?: 2 | 3 };

export function getStaticPaths() {
  const integrations = getIntegrations();

  return integrations.flatMap((integration) => [
    { params: { slug: integration.route_slug }, props: { integration, pageType: 'overview' } },
    { params: { slug: `${integration.route_slug}/lua` }, props: { integration, pageType: 'lua' } },
    { params: { slug: `${integration.route_slug}/cli` }, props: { integration, pageType: 'cli' } },
    { params: { slug: `${integration.route_slug}/mcp` }, props: { integration, pageType: 'mcp' } },
  ]);
}

const { integration, pageType } = Astro.props as {
  integration: Integration;
  pageType: PageType;
};

const primaryTool = integration.tools[0];
const pageTitle = pageType === 'overview'
  ? integrationOverviewTitle(integration)
  : pageType === 'cli'
    ? integrationCliTitle(integration)
    : pageType === 'mcp'
      ? integrationMcpTitle(integration)
      : `${integration.name} Lua API for KosmoKrator Agents`;
const pageDescription = pageType === 'overview'
  ? `${integration.name} integration docs for AI agents: MCP gateway setup, ${integration.name} CLI commands, Lua API reference, credentials, and function schemas.`
  : pageType === 'cli'
    ? `Use the ${integration.name} CLI from KosmoKrator to call ${integration.name} tools headlessly, return JSON, inspect schemas, and automate workflows from coding agents, scripts, and CI.`
    : pageType === 'mcp'
      ? `Expose ${integration.name} tools to Claude Code, Cursor, Codex, and other MCP clients through the local KosmoKrator MCP gateway.`
      : `Agent-facing Lua documentation and function reference for the ${integration.name} KosmoKrator integration.`;
const pagePath = pageType === 'overview' ? integrationUrl(integration) : integrationUrl(integration, pageType);
const pageOgImage = pageType === 'overview'
  ? ogImageUrl(['integration', integration.route_slug])
  : ogImageUrl(['integration', integration.route_slug, pageType]);
const packageUrl = `https://github.com/OpenCompanyApp/integrations/tree/main/packages/${integration.package}`;
const configureSnippet = [
  '# Install KosmoKrator first if it is not available on PATH.',
  'curl -fsSL https://raw.githubusercontent.com/OpenCompanyApp/kosmokrator/main/install.sh | bash',
  '',
  '# Configure and verify this integration.',
  integration.setup.cli_configure_command,
  integration.setup.doctor_command,
  integration.setup.status_command,
].join('\n');
const genericCallSnippet = primaryTool
  ? `kosmo integrations:call ${toolFullName(integration, primaryTool)} '${compactJsonExample(primaryTool)}' --json`
  : `kosmo integrations:docs ${integration.slug} --json`;
const providerShortcutSnippet = primaryTool
  ? `kosmo integrations:${integration.slug} ${primaryTool.function_name} '${compactJsonExample(primaryTool)}' --json`
  : `kosmo integrations:${integration.slug} --json`;
const discoverySnippet = [
  `kosmo integrations:docs ${integration.slug} --json`,
  primaryTool ? `kosmo integrations:docs ${toolFullName(integration, primaryTool)} --json` : null,
  primaryTool ? `kosmo integrations:schema ${toolFullName(integration, primaryTool)} --json` : null,
  `kosmo integrations:search "${integration.name}" --json`,
  `kosmo integrations:list --json`,
].filter(Boolean).join('\n');
const mcpJson = JSON.stringify({
  mcpServers: {
    [`kosmokrator-${integration.slug}`]: {
      type: 'stdio',
      command: 'kosmo',
      args: ['mcp:serve', `--integration=${integration.slug}`, '--write=deny'],
    },
  },
}, null, 2);
const fallbackLuaDocs = `No package Lua docs were provided. Use the function reference below for ${integration.name}.`;
const luaDocsMarkdown = integration.lua_docs || fallbackLuaDocs;
const luaDocsHtml = pageType === 'lua'
  ? (await (await createMarkdownProcessor()).render(luaDocsMarkdown)).code
  : '';
const feedbackIssueUrl = `https://github.com/OpenCompanyApp/integrations/issues/new?title=${encodeURIComponent(`${integration.name} integration feedback`)}&body=${encodeURIComponent([
  `## ${integration.name} integration feedback`,
  '',
  'Describe the missing function, credential issue, incorrect docs, runtime failure, MCP behavior, or Lua/CLI problem.',
  '',
  '## Page',
  siteUrl(pagePath),
  '',
  '## Integration metadata',
  `- slug: ${integration.slug}`,
  `- package: ${integration.package}`,
  `- page_type: ${pageType}`,
  '',
  '## Expected behavior',
  '',
  '',
  '## Actual behavior',
  '',
].join('\n'))}`;
const indexable = shouldIndexIntegration(integration);
const integrationFaqs = [
  {
    question: `Can I use ${integration.name} as a CLI?`,
    answer: `Yes. KosmoKrator exposes a ${integration.name} CLI through kosmo integrations:call and the provider shortcut command. Commands can return JSON for scripts, CI, and coding agents.`,
  },
  {
    question: `Can I expose ${integration.name} through MCP?`,
    answer: `Yes. The KosmoKrator MCP gateway can expose selected ${integration.name} tools to clients such as Claude Code, Cursor, Codex, and other MCP-compatible tools.`,
  },
  {
    question: `Where are ${integration.name} credentials stored?`,
    answer: `${integration.name} credentials are configured in KosmoKrator's local integration settings and reused by CLI, Lua, and MCP gateway surfaces.`,
  },
  {
    question: `Can I deny write access for ${integration.name} MCP tools?`,
    answer: `Yes. Start the gateway with --write=deny for read-only clients, or use ask/allow only for trusted workspaces.`,
  },
];
const pageJsonLd = [
  articleJsonLd(pageTitle, pageDescription, pagePath),
  breadcrumbJsonLd([
    { name: 'KosmoKrator', url: SITE_URL },
    { name: 'Integrations', url: siteUrl('/integrations') },
    { name: integration.name, url: siteUrl(integrationUrl(integration)) },
    ...(pagePath !== integrationUrl(integration) ? [{ name: pageTitle, url: siteUrl(pagePath) }] : []),
  ]),
  faqJsonLd(integrationFaqs),
];
const pageToc = tocForPage(pageType);
const schemaOpen = pageType === 'cli' || integration.tools.length <= 8;
const popularFunctions = integration.tools.slice(0, 10);
const hasRuntimeRequirements = integration.runtime_requirements.length > 0;
const luaNamespace = integration.slug.replace(/-/g, '_');
const luaHeadlessEvalSnippet = primaryTool
  ? `kosmo integrations:lua --eval 'dump(app.integrations.${luaNamespace}.${luaFunctionName(primaryTool)}(${luaTableExampleForTool(primaryTool)}))' --json`
  : `kosmo integrations:lua --eval 'print(docs.read("${integration.slug}"))' --json`;
const luaHeadlessDocsSnippet = primaryTool
  ? [
      `kosmo integrations:lua --eval 'print(docs.read("${integration.slug}"))' --json`,
      `kosmo integrations:lua --eval 'print(docs.read("${integration.slug}.${luaFunctionName(primaryTool)}"))' --json`,
    ].join('\n')
  : `kosmo integrations:lua --eval 'print(docs.read("${integration.slug}"))' --json`;
const luaWorkflowSnippet = primaryTool
  ? [
      `local ${luaNamespace} = app.integrations.${luaNamespace}`,
      `local result = ${luaNamespace}.${luaFunctionName(primaryTool)}(${luaTableExampleForTool(primaryTool)})`,
      '',
      'dump(result)',
    ].join('\n')
  : [
      `print(docs.read("${integration.slug}"))`,
      `dump(app.integrations.${luaNamespace})`,
    ].join('\n');
const luaWorkflowCommandSnippet = [
  'kosmo integrations:lua workflow.lua --json',
  'kosmo integrations:lua workflow.lua --force --json',
].join('\n');
const mcpLuaSnippet = [
  '# Use mcp:lua for MCP-only scripts; use integrations:lua for this integration namespace.',
  "kosmo mcp:lua --eval 'dump(mcp.servers())' --json",
].join('\n');
const luaExampleSnippet = primaryTool
  ? [
      `local result = app.integrations.${luaNamespace}.${luaFunctionName(primaryTool)}(${luaTableExampleForTool(primaryTool)})`,
      'print(result)',
    ].join('\n')
  : '';

function compactJsonExample(tool: IntegrationTool): string {
  try {
    return JSON.stringify(JSON.parse(jsonExampleForTool(tool)));
  } catch {
    return jsonExampleForTool(tool).replace(/\s+/g, ' ');
  }
}

function genericCliCommand(tool: IntegrationTool): string {
  return `kosmo integrations:call ${toolFullName(integration, tool)} '${compactJsonExample(tool)}' --json`;
}

function providerCliCommand(tool: IntegrationTool): string {
  return `kosmo integrations:${integration.slug} ${tool.function_name} '${compactJsonExample(tool)}' --json`;
}

function schemaCliCommand(tool: IntegrationTool): string {
  return `kosmo integrations:schema ${toolFullName(integration, tool)} --json`;
}

function luaTableExampleForTool(tool: IntegrationTool): string {
  return compactJsonExample(tool)
    .replace(/"([^"]+)":/g, '$1 = ')
    .replace(/,/g, ', ');
}

function luaFunctionName(tool: IntegrationTool): string {
  const snake = (tool.name || tool.function_name || tool.slug || 'tool')
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '_')
    .replace(/^_+|_+$/g, '');

  if (snake === '') {
    return 'tool';
  }

  const appBase = integration.slug.toLowerCase().replace(/s+$/g, '');
  const words = snake.split('_').filter((word) => {
    if (['on', 'of', 'for', 'in', 'to', 'the', 'a', 'an'].includes(word)) {
      return false;
    }

    const wordBase = word.replace(/s+$/g, '');

    return !wordBase.includes(appBase) && !appBase.includes(wordBase);
  });

  return words.join('_') || snake;
}

function parameterSummary(tool: IntegrationTool): string {
  const names = Object.keys(tool.parameters);
  return names.length > 0 ? names.join(', ') : 'none';
}

function tocForPage(type: PageType): TocItem[] {
  if (type === 'overview') {
    return [
      { id: 'overview', label: 'Overview' },
      { id: 'surfaces', label: 'Agent Surfaces' },
      { id: 'metadata', label: 'Metadata' },
      { id: 'catalog', label: 'Function Catalog' },
    ];
  }

  if (type === 'cli') {
    return [
      { id: 'setup', label: 'Setup' },
      { id: 'credentials', label: 'Credentials' },
      { id: 'commands', label: 'Command Patterns' },
      { id: 'automation-contexts', label: 'Automation Contexts' },
      { id: 'functions', label: 'CLI Functions' },
      { id: 'schemas', label: 'Schemas' },
      { id: 'permissions', label: 'Permissions' },
    ];
  }

  if (type === 'mcp') {
    return [
      { id: 'gateway', label: 'Gateway Setup' },
      { id: 'clients', label: 'Client Notes' },
      { id: 'tools', label: 'MCP Tool Names' },
      { id: 'write-access', label: 'Write Access' },
    ];
  }

  return [
    { id: 'namespace', label: 'Namespace' },
    { id: 'headless-lua', label: 'Headless CLI' },
    { id: 'lua-docs', label: 'Lua Docs' },
    { id: 'lua-functions', label: 'Functions' },
  ];
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle} - KosmoKrator</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={integrationKeywords(integration, pageType === 'mcp' ? matrixClients.flatMap((item) => [item.label, `${integration.name} ${item.label}`, `${item.label} MCP`]) : pageType === 'cli' ? cliEnvironments.flatMap((item) => [item.label, `${integration.name} ${item.titleSuffix}`]) : [])} />
    {!indexable && <meta name="robots" content="noindex,follow" />}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageOgImage} />
    <link rel="canonical" href={siteUrl(pagePath)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {pageJsonLd.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
    <AnalyticsContext context={{ surface: 'integration', integration_slug: integration.slug, integration_name: integration.name, page_type: pageType, category: integration.category, function_count: integration.tools.length, read_tool_count: integration.read_tool_count, write_tool_count: integration.write_tool_count, cli_runtime_supported: integration.cli_runtime_supported, mcp_gateway_supported: integration.seo.mcp_gateway_supported }} />
    <AnalyticsScripts />
  </head>
  <body class="min-h-screen text-kosmo-text font-sans bg-kosmo-bg">
    <header class="site-topbar">
      <a class="site-brand" href="/" aria-label="KosmoKrator home">
        <img src="/favicon.svg" alt="" width="28" height="28" />
        <span>KosmoKrator</span>
      </a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/integrations">Integrations</a>
        <a href="/docs/integrations">CLI docs</a>
        <a href="/docs/mcp">MCP docs</a>
        <a href={feedbackIssueUrl}>Feedback</a>
        <a href="https://github.com/OpenCompanyApp/integrations">Contribute</a>
      </nav>
    </header>

    <main class="integration-shell">
      <IntegrationSideRail integration={integration} pageType={pageType} feedbackIssueUrl={feedbackIssueUrl} packageUrl={packageUrl} />

      <article class="integration-main">
        <nav class="integration-breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a>
          <span>/</span>
          <a href="/integrations">Integrations</a>
          <span>/</span>
          <span>{integration.name}</span>
        </nav>

        <header class="integration-hero">
          <p>{integration.category}</p>
          <h1>{pageTitle}</h1>
          <span>{pageDescription}</span>
        </header>

        <nav class="surface-tabs" aria-label={`${integration.name} sections`}>
          <a class:list={[pageType === 'overview' && 'active']} href={integrationUrl(integration)}>Overview</a>
          <a class:list={[pageType === 'cli' && 'active']} href={integrationUrl(integration, 'cli')}>CLI</a>
          <a class:list={[pageType === 'mcp' && 'active']} href={integrationUrl(integration, 'mcp')}>MCP</a>
          <a class:list={[pageType === 'lua' && 'active']} href={integrationUrl(integration, 'lua')}>Lua</a>
        </nav>

        {pageType === 'overview' && (
          <div class="integration-copy content-stack">
            <section id="overview" class="content-section">
              <h2>{integration.name} for agents</h2>
              <p>{integration.compatibility_summary || integration.auth_summary}</p>
              <p>
                Use this integration from Lua code mode, the headless integrations CLI, or the KosmoKrator MCP gateway.
                The same package metadata powers all three surfaces.
              </p>
            </section>

            <section id="surfaces" class="content-section">
              <h2>Agent Surfaces</h2>
              <div class="surface-card-grid">
                <a href={integrationUrl(integration, 'cli')}><strong>{integration.name} CLI</strong><span>Headless setup, JSON output, direct function calls.</span></a>
                <a href={integrationUrl(integration, 'mcp')}><strong>{integration.name} MCP</strong><span>Expose selected tools to local MCP clients.</span></a>
                <a href={integrationUrl(integration, 'lua')}><strong>{integration.name} Lua</strong><span>Agent-facing namespace and Lua reference.</span></a>
                <a href={feedbackIssueUrl}><strong>Feedback</strong><span>Report missing tools, auth issues, or bad metadata.</span></a>
              </div>
            </section>

            <section id="metadata" class="content-section">
              <h2>Machine-Readable Metadata</h2>
              <dl class="metadata-grid">
                <div><dt>integration_slug</dt><dd><code>{integration.slug}</code></dd></div>
                <div><dt>route_slug</dt><dd><code>{integration.route_slug}</code></dd></div>
                <div><dt>package</dt><dd><code>{integration.package}</code></dd></div>
                <div><dt>auth_strategy</dt><dd><code>{integration.auth_strategy}</code></dd></div>
                <div><dt>cli_setup_supported</dt><dd><code>{String(integration.cli_setup_supported)}</code></dd></div>
                <div><dt>cli_runtime_supported</dt><dd><code>{String(integration.cli_runtime_supported)}</code></dd></div>
                <div><dt>mcp_gateway_supported</dt><dd><code>{String(integration.seo.mcp_gateway_supported)}</code></dd></div>
                <div><dt>lua_supported</dt><dd><code>{String(integration.seo.lua_supported)}</code></dd></div>
              </dl>
            </section>

            {hasRuntimeRequirements && (
              <section class="content-section">
                <h2>Runtime Requirements</h2>
                <div class="tool-table-wrapper compact">
                  <table>
                    <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
                    <tbody>
                      {integration.runtime_requirements.map((requirement) => (
                        <tr>
                          <td data-label="Name"><code>{String(requirement.name ?? 'runtime')}</code></td>
                          <td data-label="Type">{String(requirement.type ?? 'dependency')}</td>
                          <td data-label="Description">{String(requirement.description ?? '')}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}

            <section id="catalog" class="content-section">
              <h2>Function Catalog</h2>
              <div class="tool-table-wrapper">
                <table>
                  <thead><tr><th>Function</th><th>Type</th><th>Parameters</th><th>Description</th></tr></thead>
                  <tbody>
                    {integration.tools.map((tool) => (
                      <tr>
                        <td data-label="Function"><code>{toolFullName(integration, tool)}</code></td>
                        <td data-label="Type">{operationLabel(tool.type)} <code>{tool.type}</code></td>
                        <td data-label="Parameters">{tool.parameter_count}</td>
                        <td data-label="Description">{tool.description || tool.short_description || tool.name}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>
          </div>
        )}

        {pageType === 'cli' && (
          <div class="integration-copy content-stack">
            <section id="setup" class="content-section">
              <h2>{integration.name} CLI Setup</h2>
              <p>{integration.setup.cli_setup_summary || integration.seo.cli_setup_summary}</p>
              {!integration.cli_setup_supported && (
                <p class="callout">Headless setup is limited for this integration. It remains documented because stored credentials or future proxy-backed execution can still make the runtime useful.</p>
              )}
              <CommandBlock label="Install, configure, and verify" code={configureSnippet} />
            </section>

            {hasRuntimeRequirements && (
              <section class="content-section">
                <h2>Runtime Requirements</h2>
                <p>Install these host dependencies before calling {integration.name} locally.</p>
                <div class="tool-table-wrapper compact">
                  <table>
                    <thead><tr><th>Name</th><th>Type</th><th>Description</th></tr></thead>
                    <tbody>
                      {integration.runtime_requirements.map((requirement) => (
                        <tr>
                          <td data-label="Name"><code>{String(requirement.name ?? 'runtime')}</code></td>
                          <td data-label="Type">{String(requirement.type ?? 'dependency')}</td>
                          <td data-label="Description">{String(requirement.description ?? '')}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </section>
            )}

            <section id="credentials" class="content-section">
              <h2>Credentials</h2>
              <p>
                Authentication type: <strong>{integration.auth_strategy_label}</strong>
                <code>{integration.auth_strategy}</code>. Configure credentials once, then reuse the same stored profile from scripts, coding CLIs, Lua, and MCP.
              </p>
              {integration.credentials.length > 0 ? (
                <div class="tool-table-wrapper compact">
                  <table>
                    <thead><tr><th>Key</th><th>Env var</th><th>Type</th><th>Required</th><th>Label</th></tr></thead>
                    <tbody>
                      {integration.credentials.map((field, index) => (
                        <tr>
                          <td data-label="Key"><code>{field.key}</code></td>
                          <td data-label="Env var"><code>{integration.setup.env_vars[index] ?? ''}</code></td>
                          <td data-label="Type">{credentialTypeLabel(field.type)} <code>{field.type}</code></td>
                          <td data-label="Required">{field.required ? 'yes' : 'no'}</td>
                          <td data-label="Label">{field.label}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              ) : <p>No credentials are required.</p>}
            </section>

            <section id="commands" class="content-section">
              <h2>Command Patterns</h2>
              <p>The generic command is stable across every integration. The provider shortcut is shorter for humans.</p>
              <div class="command-grid">
                <CommandBlock label="Generic CLI call" code={genericCallSnippet} analyticsProps={{ command_surface: 'page_primary', command_type: 'generic' }} />
                <CommandBlock label="Provider shortcut" code={providerShortcutSnippet} analyticsProps={{ command_surface: 'page_primary', command_type: 'shortcut' }} />
              </div>
              <h3>Discovery</h3>
              <p>These commands return structured output for coding agents that need to inspect capabilities before choosing a function.</p>
              <CommandBlock label="Discovery commands" code={discoverySnippet} analyticsProps={{ command_surface: 'discovery' }} />
            </section>

            <section id="automation-contexts" class="content-section">
              <h2>Automation Contexts</h2>
              <p>
                The same configured command surface works in these environments. The command does not change unless the host wrapper, credentials, or permissions change.
              </p>
              <div class="context-grid">
                {cliEnvironments.map((item) => (
                  <a href={`#functions`}>
                    <strong>{item.titleSuffix}</strong>
                    <span>{item.description}</span>
                  </a>
                ))}
              </div>
            </section>

            <section id="functions" class="content-section">
              <h2>CLI Functions</h2>
              <p>
                Every function below can be called headlessly. Commands are highlighted, copyable, and scroll horizontally when payloads are long.
              </p>
              <div class="function-list">
                {integration.tools.map((tool) => (
                  <article id={`cli-${tool.function_name}`} class="function-entry">
                    <header>
                      <div>
                        <h3><code>{toolFullName(integration, tool)}</code></h3>
                        <p>{tool.description || tool.short_description || tool.name}</p>
                      </div>
                      <span>{operationLabel(tool.type)} <code>{tool.type}</code></span>
                    </header>
                    <dl>
                      <div><dt>Parameters</dt><dd>{parameterSummary(tool)}</dd></div>
                    </dl>
                    <div class="command-grid">
                      <CommandBlock compact label="Generic call" code={genericCliCommand(tool)} />
                      <CommandBlock compact label="Shortcut" code={providerCliCommand(tool)} />
                    </div>
                  </article>
                ))}
              </div>
            </section>

            <section id="schemas" class="content-section">
              <h2>Function Schemas</h2>
              <p>Use these parameter tables when building CLI payloads without calling <code>integrations:schema</code> first.</p>
              <div class="schema-list">
                {integration.tools.map((tool) => (
                  <details
                    class="function-details"
                    id={`schema-${tool.function_name}`}
                    open={schemaOpen}
                    data-analytics-event="integration_schema_viewed"
                    data-analytics-surface="schema"
                  >
                    <summary>
                      <span><code>{toolFullName(integration, tool)}</code></span>
                      <small>{tool.parameter_count} parameters</small>
                    </summary>
                    <div class="function-details-body">
                      <CommandBlock compact label="Schema command" code={schemaCliCommand(tool)} />
                      <div class="tool-table-wrapper compact">
                        <table>
                          <thead><tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                          <tbody>
                            {Object.entries(tool.parameters).length > 0 ? Object.entries(tool.parameters).map(([name, schema]) => (
                              <tr>
                                <td data-label="Parameter"><code>{name}</code></td>
                                <td data-label="Type">{String(schema.type ?? 'mixed')}</td>
                                <td data-label="Required">{schema.required ? 'yes' : 'no'}</td>
                                <td data-label="Description">{String(schema.description ?? '')}</td>
                              </tr>
                            )) : (
                              <tr><td colspan="4">No parameters.</td></tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </details>
                ))}
              </div>
            </section>

            <section id="permissions" class="content-section">
              <h2>Permissions</h2>
              <p>
                Headless calls still follow the integration read/write permission policy. Configure read/write defaults with
                <code>integrations:configure</code>. Add <code>--force</code> only for trusted automation that should bypass that policy.
              </p>
            </section>
          </div>
        )}

        {pageType === 'mcp' && (
          <div class="integration-copy content-stack">
            <section id="gateway" class="content-section">
              <h2>{integration.name} MCP Gateway</h2>
              <p>{integration.setup.mcp_setup_summary || integration.seo.mcp_setup_summary}</p>
              <p>If the client has never used KosmoKrator before, install it first, then register this integration as a stdio MCP server.</p>
              <CommandBlock label="Install KosmoKrator" code="curl -fsSL https://raw.githubusercontent.com/OpenCompanyApp/kosmokrator/main/install.sh | bash" analyticsProps={{ command_surface: 'mcp_gateway', install_target: 'kosmokrator' }} />
              <CommandBlock label="Install gateway entry" code={integration.setup.mcp_gateway_install_command} analyticsProps={{ command_surface: 'mcp_gateway', install_target: 'gateway_entry' }} />
              <CommandBlock label="MCP configuration" code={mcpJson} lang="json" analyticsProps={{ command_surface: 'mcp_gateway', client: 'generic_mcp' }} />
              <CommandBlock label="Serve manually" code={integration.setup.mcp_gateway_serve_command} analyticsProps={{ command_surface: 'mcp_gateway', command_type: 'serve' }} />
            </section>

            <section id="clients" class="content-section">
              <h2>Client Notes</h2>
              <p>Use one scoped MCP gateway entry, then adapt the config location to the client or framework.</p>
              <div class="context-grid">
                {matrixClients.map((item) => (
                  <section id={item.slug}>
                    <strong>{item.label}</strong>
                    <span>{item.description} {item.installHint}</span>
                  </section>
                ))}
              </div>
            </section>

            <section id="tools" class="content-section">
              <h2>MCP Tool Names</h2>
              <p>KosmoKrator exposes integration tools through the gateway with stable names.</p>
              <div class="tool-table-wrapper">
                <table>
                  <thead><tr><th>MCP tool</th><th>Source function</th><th>Type</th></tr></thead>
                  <tbody>
                    {integration.tools.map((tool) => (
                      <tr>
                        <td data-label="MCP tool"><code>{toolMcpName(integration, tool)}</code></td>
                        <td data-label="Source"><code>{toolFullName(integration, tool)}</code></td>
                        <td data-label="Type">{operationLabel(tool.type)} <code>{tool.type}</code></td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </section>

            <section id="write-access" class="content-section">
              <h2>Write Access</h2>
              <p>
                Start with <code>--write=deny</code> for read-only MCP clients. Use <code>--write=ask</code> or
                <code> --write=allow</code> only when the client and workspace are trusted.
              </p>
            </section>
          </div>
        )}

        {pageType === 'lua' && (
          <div class="integration-copy content-stack">
            <section id="namespace" class="content-section">
              <h2>Lua Namespace</h2>
              <p>
                Agents call this integration through <code>app.integrations.{luaNamespace}.*</code>.
                Use <code>lua_read_doc("integrations.{integration.slug}")</code> inside KosmoKrator to discover the same reference at runtime.
              </p>
            </section>

            <section id="headless-lua" class="content-section">
              <h2>Call Lua from the Headless CLI</h2>
              <p>
                Use <code>kosmo integrations:lua</code> when a shell script, CI job, cron job, or another coding CLI should run a deterministic
                {integration.name} workflow without starting an interactive agent session.
              </p>
              <div class="command-grid">
                <CommandBlock label="Inline Lua call" code={luaHeadlessEvalSnippet} analyticsProps={{ example_type: 'inline', command_surface: 'headless_lua' }} />
                <CommandBlock label="Read Lua docs headlessly" code={luaHeadlessDocsSnippet} analyticsProps={{ example_type: 'docs', command_surface: 'headless_lua' }} />
              </div>
              <h3>Workflow file</h3>
              <p>Put repeatable logic in a Lua file, then execute it with JSON output for the calling process.</p>
              <CommandBlock label="workflow.lua" code={luaWorkflowSnippet} lang="lua" analyticsProps={{ example_type: 'workflow', command_surface: 'headless_lua' }} />
              <CommandBlock label="Run the workflow" code={luaWorkflowCommandSnippet} analyticsProps={{ example_type: 'workflow_command', command_surface: 'headless_lua' }} />
              <div class="callout">
                <strong>Namespace note.</strong> <code>integrations:lua</code> exposes <code>app.integrations.{luaNamespace}</code>, <code>app.mcp.*</code>, <code>docs.*</code>, <code>json.*</code>, and <code>regex.*</code>. Use <code>app.integrations.{luaNamespace}.default.*</code> or <code>app.integrations.{luaNamespace}.work.*</code> when you configured named credential accounts.
              </div>
              <h3>MCP-only Lua</h3>
              <p>If the script only needs configured MCP servers and does not need {integration.name}, use the narrower <code>mcp:lua</code> command.</p>
              <CommandBlock label="MCP Lua command" code={mcpLuaSnippet} analyticsProps={{ example_type: 'mcp', command_surface: 'headless_lua' }} />
            </section>

            <section id="lua-docs" class="content-section">
              <h2>Agent-Facing Lua Docs</h2>
              <p>This is the rendered version of the full Lua documentation exposed to agents when they inspect the integration namespace.</p>
              <div class="rendered-lua-docs" set:html={luaDocsHtml} />
              <details class="raw-docs-details">
                <summary>Raw agent markdown</summary>
                <pre class="raw-docs"><code>{luaDocsMarkdown}</code></pre>
              </details>
              {primaryTool && <CommandBlock label="Metadata-derived Lua example" code={luaExampleSnippet} lang="lua" analyticsProps={{ example_type: 'metadata', command_surface: 'lua_reference', function_name: luaFunctionName(primaryTool) }} />}
            </section>

            <section id="lua-functions" class="content-section">
              <h2>Functions</h2>
              <div class="schema-list">
                {integration.tools.map((tool) => (
                  <details
                    class="function-details"
                    id={luaFunctionName(tool)}
                    open={schemaOpen}
                    data-analytics-event="integration_function_opened"
                    data-analytics-surface="lua"
                  >
                    <summary>
                      <span><code>{luaFunctionName(tool)}</code></span>
                      <small>{operationLabel(tool.type)}</small>
                    </summary>
                    <div class="function-details-body">
                      <p>{tool.description || tool.short_description || tool.name}</p>
                      <dl>
                        <div><dt>Lua path</dt><dd><code>app.integrations.{luaNamespace}.{luaFunctionName(tool)}</code></dd></div>
                        <div><dt>Full name</dt><dd><code>{toolFullName(integration, tool)}</code></dd></div>
                      </dl>
                      <div class="tool-table-wrapper compact">
                        <table>
                          <thead><tr><th>Parameter</th><th>Type</th><th>Required</th><th>Description</th></tr></thead>
                          <tbody>
                            {Object.entries(tool.parameters).length > 0 ? Object.entries(tool.parameters).map(([name, schema]) => (
                              <tr>
                                <td data-label="Parameter"><code>{name}</code></td>
                                <td data-label="Type">{String(schema.type ?? 'mixed')}</td>
                                <td data-label="Required">{schema.required ? 'yes' : 'no'}</td>
                                <td data-label="Description">{String(schema.description ?? '')}</td>
                              </tr>
                            )) : (
                              <tr><td colspan="4">No parameters.</td></tr>
                            )}
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </details>
                ))}
              </div>
            </section>
          </div>
        )}
      </article>

      <IntegrationToc items={pageToc} />
    </main>

    <MegaFooter />

  </body>
</html>
