---
import '../../styles/tailwind.css';
import MegaFooter from '../../components/MegaFooter.astro';
import {
  SITE_URL,
  articleJsonLd,
  breadcrumbJsonLd,
  jsonLd,
  matrixClients,
  ogImageUrl,
  siteUrl,
  useCasePages,
  type UseCasePage,
} from '../../lib/seo';

export function getStaticPaths() {
  return useCasePages.map((page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props as { page: UseCasePage };
const pagePath = `/use-cases/${page.slug}`;
const pageOgImage = ogImageUrl(['use-case', page.slug]);
const schemas = [
  articleJsonLd(page.title, page.description, pagePath),
  breadcrumbJsonLd([
    { name: 'KosmoKrator', url: SITE_URL },
    { name: 'Use Cases', url: siteUrl('/use-cases/local-mcp-gateway') },
    { name: page.h1, url: siteUrl(pagePath) },
  ]),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{page.title}</title>
    <meta name="description" content={page.description} />
    <meta name="keywords" content={`${page.h1}, KosmoKrator, terminal AI coding agent, local MCP gateway, AI agent CLI, headless automation`} />
    <meta property="og:title" content={page.title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:image" content={pageOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={pageOgImage} />
    <link rel="canonical" href={siteUrl(pagePath)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {schemas.map((schema) => <script type="application/ld+json" set:html={jsonLd(schema)} />)}
  </head>
  <body class="min-h-screen m-0 text-kosmo-text font-sans bg-[radial-gradient(circle_at_12%_0%,rgba(220,20,60,0.14),transparent_28rem),linear-gradient(180deg,#07070d_0%,#0d0d15_56%,#07070d_100%)]">
    <header class="w-[min(1180px,calc(100%_-_2.5rem))] mx-auto flex items-center justify-between gap-4 py-[1.1rem] max-[640px]:flex-col max-[640px]:items-start">
      <a class="text-kosmo-text no-underline font-extrabold flex items-center gap-4" href="/" aria-label="KosmoKrator home">
        <img src="/favicon.svg" alt="" width="28" height="28" />
        <span>KosmoKrator</span>
      </a>
      <nav class="flex flex-wrap items-center justify-end gap-4" aria-label="Main navigation">
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/docs/getting-started">Docs</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/integrations">Integrations</a>
        <a class="text-kosmo-muted hover:text-kosmo-text no-underline text-[0.94rem]" href="/compare/composio">Compare</a>
      </nav>
    </header>

    <main class="w-[min(1080px,calc(100%_-_2.5rem))] mx-auto py-12 pb-20">
      <section class="max-w-[900px] mb-8">
        <p class="m-0 mb-[0.7rem] text-kosmo-hot text-[0.78rem] font-extrabold tracking-[0.14em] uppercase">Use case</p>
        <h1 class="m-0 leading-[1.04] text-[clamp(2.4rem,5vw,4.1rem)]">{page.h1}</h1>
        <p class="text-kosmo-muted leading-[1.7]">{page.description}</p>
      </section>

      <section class="grid grid-cols-[repeat(auto-fit,minmax(230px,1fr))] gap-3 my-8">
        <div class="p-4 border border-kosmo-white-border rounded-lg bg-kosmo-surface">
          <strong>Best for</strong>
          <p class="text-kosmo-muted leading-relaxed">{page.audience}.</p>
        </div>
        <div class="p-4 border border-kosmo-white-border rounded-lg bg-kosmo-surface">
          <strong>Primary surface</strong>
          <p class="text-kosmo-muted leading-relaxed">Terminal, headless CLI, MCP gateway, Lua, ACP, and PHP SDK surfaces share the same local runtime.</p>
        </div>
        <div class="p-4 border border-kosmo-white-border rounded-lg bg-kosmo-surface">
          <strong>Control model</strong>
          <p class="text-kosmo-muted leading-relaxed">Use local credentials, provider configuration, integration policy, and explicit write controls.</p>
        </div>
      </section>

      <section class="my-8 p-5 border border-kosmo-border rounded-lg bg-kosmo-surface-solid">
        <h2 class="mt-0">Start Here</h2>
        <p class="text-kosmo-muted leading-relaxed">The implementation details live in the product docs and generated integration catalog.</p>
        <a class="inline-flex items-center justify-center min-h-[44px] px-4 py-3 border rounded-md text-kosmo-text font-bold no-underline bg-kosmo-crimson border-kosmo-crimson" href={page.primaryLink}>Open the relevant docs</a>
      </section>

      <section>
        <h2>Related MCP Client Pages</h2>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(230px,1fr))] gap-3">
          {matrixClients.slice(0, 6).map((client) => (
            <a class="grid gap-1.5 p-4 border border-kosmo-white-border rounded-lg bg-kosmo-surface text-kosmo-text no-underline hover:border-kosmo-crimson" href={`/mcp/${client.slug}`}>
              <strong>{client.label}</strong>
              <span class="text-kosmo-muted">Use KosmoKrator as a local MCP gateway for {client.shortLabel}.</span>
            </a>
          ))}
        </div>
      </section>
    </main>
    <MegaFooter />
  </body>
</html>
